# ============================================================
# D&D 5e Assistant — 环境变量配置
# 复制本文件为 .env.local（本地）或在部署平台填入对应的环境变量
# ============================================================

# ── 聊天 LLM ────────────────────────────────────────────────
# 推荐：DeepSeek（性价比最高，支持中文）
OPENAI_API_KEY=sk-your-deepseek-key-here
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_CHAT_MODEL=deepseek-chat

# 其他选项：
# OpenAI:       OPENAI_BASE_URL=https://api.openai.com/v1  OPENAI_CHAT_MODEL=gpt-4o-mini
# 月之暗面:     OPENAI_BASE_URL=https://api.moonshot.cn/v1  OPENAI_CHAT_MODEL=moonshot-v1-8k
# 零一万物:     OPENAI_BASE_URL=https://api.lingyiwanwu.com/v1  OPENAI_CHAT_MODEL=yi-large

# ── Embedding（向量化）──────────────────────────────────────
# 推荐：硅基流动（免费额度，768维，与本地Ollama nomic-embed-text维度一致）
EMBED_API_KEY=sk-your-siliconflow-key-here
EMBED_BASE_URL=https://api.siliconflow.cn/v1
OPENAI_EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
OPENAI_EMBEDDING_DIM=1024

# 备选：OpenAI embedding（需付费，效果好）
# EMBED_API_KEY=sk-your-openai-key-here
# EMBED_BASE_URL=https://api.openai.com/v1
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_EMBEDDING_DIM=1536

# 本地 Ollama（仅本地开发）：
# EMBED_API_KEY=ollama
# EMBED_BASE_URL=http://localhost:11434/v1
# OPENAI_EMBEDDING_MODEL=nomic-embed-text
# OPENAI_EMBEDDING_DIM=768

# ── 数据库路径 ───────────────────────────────────────────────
# 本地：./data/dnd.db
# Railway：/data/dnd.db（挂载持久化磁盘到 /data）
DATABASE_PATH=./data/dnd.db

# ── 应用 ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=D&D 5e Assistant
